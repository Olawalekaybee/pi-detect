# Pi-Detect — environment configuration
# Copy this file: cp .env.example .env
# Then edit .env with your actual values (never commit .env to git)

# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
SECRET_KEY=replace-with-a-random-secret

# ── Camera ─────────────────────────────────────────────────────
# true  = use PiCamera2 (on Raspberry Pi hardware)
# false = use OpenCV webcam (on laptop for dev)
USE_PICAMERA=true
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
WEBCAM_INDEX=0          # ignored when USE_PICAMERA=true

# ── Detection ──────────────────────────────────────────────────
MODEL_NAME=yolov8n.pt
MODEL_PATH=models/yolov8n.pt
CONFIDENCE_THRESHOLD=0.45
IOU_THRESHOLD=0.45
MAX_DETECTIONS=20
# Run detection every N frames (3-5 is sweet-spot on Pi Zero 2W)
DETECTION_SKIP_FRAMES=3
DEVICE=cpu

# ── Streaming ──────────────────────────────────────────────────
STREAM_QUALITY=70       # JPEG quality 1-100 (lower = faster over 4G)
STREAM_MAX_FPS=15

# ── Ngrok (for 4G remote access) ───────────────────────────────
# Get your free token at https://dashboard.ngrok.com
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pi-detect.log
